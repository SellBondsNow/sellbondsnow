# sellbonds.now — example env file
# Copy to .env and fill in real values. Real .env is gitignored.

# --- AWS (SES→Lambda→Resend email forwarder; account 729859599060 only) ---
AWS_ACCOUNT_ID=729859599060
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# --- Blockchain / deploy ---
# Dedicated project keys — NEVER a personal wallet.
DEPLOYER_PRIVATE_KEY=0x...           # deploys the stack; becomes ArchController owner
FAUCET_RELAYER_PRIVATE_KEY=0x...     # TESTNET gas dispenser hot wallet (Base Sepolia only;
                                     # do NOT fund this on mainnet)

# RPC endpoints, one per network.
RPC_URL_BASE=https://mainnet.base.org           # Base mainnet (chain id 8453, default)
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org   # Base Sepolia testnet (chain id 84532)
