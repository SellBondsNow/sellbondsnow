    "name": "sellbondsnow",
    "install": [
      "npx skills add sellbondsnow/skill --skill sellbondsnow -g",
      "npm install -g sellbonds",
      "curl -fsSL https://sellbonds.now/install.sh | bash"
    ]
  },
  "cli": {
    "package": "sellbonds",
    "command": "sbn",
    "install": "npm install -g sellbonds"
